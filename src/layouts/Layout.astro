---
import "../styles/global.css";
import Navbar from "../components/Navbar.svelte";
import Footer from "../components/Footer.svelte";
import ClosedModal from "../components/ClosedModal.svelte";
import PromoModal from "../components/PromoModal.svelte";

const { title = 'Digital Center | Tu mejor opción en tecnología' } = Astro.props;

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000';
let initialSettings = null;
try {
    const res = await fetch(`${API_URL}/settings/`);
    if (res.ok) {
        initialSettings = await res.json();
    }
} catch(err) {
    console.error("Failed to load settings from DB");
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Digital Center - Tienda Electrónica</title>
    <!-- Google Fonts para Aesthetics -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline define:vars={{ initialSettings }}>
      // Step 1: Store server data in a global variable BEFORE any component hydrates
      if (initialSettings) {
        window.__siteSettings = initialSettings;
        // Also set localStorage as backup for first render
        localStorage.setItem('site_settings:logoUrl', initialSettings.logo_url || '');
        localStorage.setItem('site_settings:footerLocation', initialSettings.footer_location || '');
        localStorage.setItem('site_settings:whatsappPhone', initialSettings.whatsapp_phone || '');
        localStorage.setItem('site_settings:attentionSchedule', initialSettings.attention_schedule || '');
        localStorage.setItem('site_settings:isAttentionVisible', String(initialSettings.is_attention_visible));
        localStorage.setItem('site_settings:isClosedToday', String(initialSettings.is_closed_today));
        localStorage.setItem('site_settings:contactEmail', initialSettings.contact_email || '');
      }
    </script>
  </head>
  <body
    class="bg-[#0b0f19] text-gray-100 font-['Outfit'] min-h-screen flex flex-col selection:bg-indigo-500/30"
  >
    <Navbar client:only="svelte" />
    <main class="flex-grow scroll-smooth">
      <slot />
    </main>
    <Footer client:only="svelte" />
    <ClosedModal client:load />
    <PromoModal client:load />
    <!-- Step 2: Module script that updates the store reactively after hydration -->
    <script>
      import { settingsStore } from '../stores/settings';
      const s = window.__siteSettings;
      if (s) {
        settingsStore.setKey('logoUrl', s.logo_url || '');
        settingsStore.setKey('footerLocation', s.footer_location || '');
        settingsStore.setKey('whatsappPhone', s.whatsapp_phone || '');
        settingsStore.setKey('attentionSchedule', s.attention_schedule || '');
        settingsStore.setKey('isAttentionVisible', s.is_attention_visible ?? true);
        settingsStore.setKey('isClosedToday', s.is_closed_today ?? false);
        settingsStore.setKey('contactEmail', s.contact_email || '');
      }
    </script>
  </body>
</html>

<style is:global>
  /* Optimizaciones generales */
  html {
    scroll-behavior: smooth;
  }
  * {
    box-sizing: border-box;
  }
  body {
    margin: 0;
  }

  /* Scrollbar Aesthetic */
  ::-webkit-scrollbar {
    width: 8px;
  }
  ::-webkit-scrollbar-track {
    background: #0b0f19;
  }
  ::-webkit-scrollbar-thumb {
    background: #1f2937;
    border-radius: 4px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #374151;
  }

  /* Utilerías Glassmorphism global */
  .glassmorphism {
    background: rgba(17, 24, 39, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }
</style>
